# ── LLM ──
DEEPSEEK_API_KEY=replace-with-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
SMART_TRIP_USE_DEEPSEEK=1

# ── Local LLM (optional) ──
# SMART_TRIP_USE_OLLAMA=1
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b

# ── Weather ──
# Open-Meteo is always used as the free fallback (no key needed).
# 和风天气 (QWeather) for better Chinese city coverage, optional:
# QWEATHER_API_KEY=your-qweather-key

# ── 代理模式 ──
# 启用 LangChain ReAct Agent 替代正则规则引擎
# SMART_TRIP_USE_AGENT=1

# ── 高德地图 (Amap) ──
# POI search, geocoding, and static maps for Chinese cities.
# Get a free key at: https://console.amap.com/dev/
# AMAP_API_KEY=your-amap-key
